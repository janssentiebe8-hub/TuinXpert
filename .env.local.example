# =============================================================
# Xandro's Tuinen — Omgevingsvariabelen
# =============================================================
# Kopieer dit bestand naar .env.local en vul de waarden in.
# .env.local wordt NOOIT naar git gepushed (staat in .gitignore).
# =============================================================

# -------------------------------------------------------------
# E-mail via Resend (vereist voor contactformulier)
# -------------------------------------------------------------
# Stap 1: Gratis account aanmaken op https://resend.com
# Stap 2: Ga naar API Keys → Create API Key
# Stap 3: Plak de key hieronder

RESEND_API_KEY=re_JOUW_API_KEY_HIER

# -------------------------------------------------------------
# DNS-records voor e-mail deliverability (instellen bij je domeinregistrar)
# -------------------------------------------------------------
# Zonder deze records belanden mails in de spam van ontvangers.
#
# SPF-record (TXT op @):
#   v=spf1 include:amazonses.com ~all
#   (Resend gebruikt Amazon SES onder de motorkap)
#
# DKIM-record:
#   Resend toont de exacte DNS-records na domeinverificatie
#   op https://resend.com/domains → Add Domain → xandrostuinen.be
#
# DMARC-record (TXT op _dmarc):
#   v=DMARC1; p=none; rua=mailto:XandroTuin111@hotmail.com
# -------------------------------------------------------------
